{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flutter: Run Windows App",
      "type": "node-terminal",
      "request": "launch",
      "command": "flutter run -d windows",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Flutter: Run Built Windows App",
      "type": "node-terminal",
      "request": "launch",
      "command": "${workspaceFolder}/build/windows/x64/runner/Release/catcheye_guard_app.exe",
      "cwd": "${workspaceFolder}"
      // "preLaunchTask": "Flutter: Build Windows"
    }
  ]
}
